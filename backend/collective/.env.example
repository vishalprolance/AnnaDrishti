# Environment
ENVIRONMENT=staging

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-aws-account-id

# DynamoDB Tables
INVENTORY_TABLE_NAME=collective-inventory-staging
CONTRIBUTIONS_TABLE_NAME=farmer-contributions-staging
RESERVATIONS_TABLE_NAME=reservations-staging

# PostgreSQL Database (if enabled)
DB_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:account-id:secret:collective-db-credentials-staging
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collective_selling
DB_USERNAME=collective_admin
DB_PASSWORD=your-password-here

# Feature Flags
FEATURE_FLAG_COLLECTIVE_MODE=true
FEATURE_FLAG_RDS_ENABLED=false

# API Configuration
API_KEY=your-api-key-here
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGGING=true

# Testing
TEST_MODE=false
USE_MOCK_DATA=false
