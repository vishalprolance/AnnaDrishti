# AWS Configuration
CDK_DEFAULT_ACCOUNT=your-aws-account-id
CDK_DEFAULT_REGION=ap-south-1

# Environment
ENVIRONMENT=staging

# Feature Flags
FEATURE_FLAG_COLLECTIVE_MODE=true
FEATURE_FLAG_RDS_ENABLED=false

# Database Configuration (if RDS is enabled)
DB_NAME=collective_selling
DB_USERNAME=collective_admin
# DB_PASSWORD is stored in AWS Secrets Manager

# API Configuration
API_THROTTLE_BURST_LIMIT=100
API_THROTTLE_RATE_LIMIT=50

# Monitoring
CLOUDWATCH_RETENTION_DAYS=7
ENABLE_DETAILED_MONITORING=true

# Deployment
ENABLE_POINT_IN_TIME_RECOVERY=false
ENABLE_DELETION_PROTECTION=false
